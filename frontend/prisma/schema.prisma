generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ROOKIE
  CAPITAL
  LEYENDA
  ADMIN
}

enum Status {
  ACTIVE
  SUSPENDED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  DIRECT
}

// Global System Configuration Settings
model SystemSetting {
  key       String   @id @unique
  value     String
  category  String   @default("system") // e.g., "api_keys", "feature_flags"
  updatedAt DateTime @updatedAt
}


model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  role      Role     @default(ROOKIE)
  status    Status   @default(ACTIVE)
  
  // Geolocation & Profile
  location          String?
  city              String?
  country           String?
  isArtist          Boolean  @default(false)
  
  // Monetization
  balance           Float    @default(0)
  subscriptions     Subscription[] @relation("UserSubscriptions")
  subscribers       Subscription[] @relation("ArtistSubscribers")
  transactions      Transaction[]

  projects         Project[]
  tickets          SupportTicket[]
  instrumentModels InstrumentModel[]
  playlists        Playlist[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  name        String
  duration    Int      @default(0) // Duration in seconds
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SupportTicket {
  id          String       @id @default(cuid())
  subject     String
  message     String
  status      TicketStatus @default(OPEN)
  priority    Priority     @default(LOW)
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model InstrumentModel {
  id          String   @id @default(cuid())
  name        String
  description String?
  tags        String[]
  weightsUrl  String?  // Storage URL for the trained model
  baseModel   String   @default("stabilityai/stable-audio-open-1.0")
  samples     InstrumentSample[]
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InstrumentSample {
  id                String   @id @default(cuid())
  name              String
  audioUrl          String
  midiUrl           String?
  prompt            String
  metadata          Json?    // Combined metadata from Spotify/Last.fm
  instrumentModelId String
  instrumentModel   InstrumentModel @relation(fields: [instrumentModelId], references: [id])
  playlistTracks    PlaylistTrack[]
  publishing        Publishing?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
model Playlist {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  tracks      PlaylistTrack[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id])
  sampleId   String
  sample     InstrumentSample @relation(fields: [sampleId], references: [id])
  createdAt  DateTime @default(now())
}

model MasteringDNA {
  id              String   @id @default(cuid())
  profileName     String
  genre           String
  dnaData         Json     // The sonic profile JSON
  isGoldStandard  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Subscription {
  id           String   @id @default(cuid())
  subscriberId String
  subscriber   User     @relation("UserSubscriptions", fields: [subscriberId], references: [id])
  artistId     String
  artist       User     @relation("ArtistSubscribers", fields: [artistId], references: [id])
  status       String   @default("active") // active, cancelled, past_due
  price        Float
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([subscriberId, artistId])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  amount    Float
  type      String   // GIFT, SUBSCRIPTION, WITHDRAWAL
  status    String   @default("PENDING") // PENDING, COMPLETED, FAILED
  fee       Float    @default(0)
  metadata  Json?
  createdAt DateTime @default(now())
}

model Publishing {
  id          String   @id @default(cuid())
  trackId     String   @unique
  track       InstrumentSample @relation(fields: [trackId], references: [id])
  rightsOrg   String   // ASCAP, BMI, SESAC
  workId      String?  // The ID assigned by the rights organization
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  systemShare Float    @default(0.50)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
